generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Restaurant (tenant)
model Restaurant {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  name        String
  currency    String   @default("EUR")
  locale      String   @default("de")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  menus          Menu[]
  categories     Category[]
  dishes         Dish[]
  qrCodes        QrCode[]
  emailTemplates EmailTemplate[]
  emailLogs      EmailLog[]
  jobs           Job[]
  applicants     Applicant[]
}

// Menu groups dishes together
model Menu {
  id           String   @id @default(cuid())
  restaurantId String
  name         String   @default("Speisekarte")
  isActive     Boolean  @default(true)
  slug         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  qrCodes    QrCode[]

  @@unique([restaurantId, slug])
}

// Category (Vorspeise, Hauptgang, Desserts, Getränke...)
model Category {
  id           String   @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes     Dish[]

  @@index([restaurantId, sortOrder])
}

// Dish
model Dish {
  id           String   @id @default(cuid())
  restaurantId String
  categoryId   String
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  allergens    String[] // EU allergen codes: A-N (14 Hauptallergene)
  isVisible    Boolean  @default(true)
  sortOrder    Int      @default(0)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category   Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants   DishVariant[]

  @@index([restaurantId, categoryId, sortOrder])
}

// Dish variant (e.g. "Klein 0.3l", "Groß 0.5l")
model DishVariant {
  id        String   @id @default(cuid())
  dishId    String
  label     String   // e.g. "Klein", "Groß", "Familienportion"
  price     Decimal  @db.Decimal(10, 2)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@index([dishId, sortOrder])
}

// QR Code linking to a menu
model QrCode {
  id           String   @id @default(cuid())
  restaurantId String
  menuId       String
  label        String   // e.g. "Tisch 1", "Bar", "Terrasse"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

// ─── BewerbungsBoard: Kern-Modelle ───

enum ApplicationStage {
  EINGANG
  SCREENING
  INTERVIEW
  ANGEBOT
  EINGESTELLT
  ABGELEHNT
}

enum JobType {
  VOLLZEIT
  TEILZEIT
  MINIJOB
  AUSBILDUNG
  PRAKTIKUM
}

model Job {
  id           String   @id @default(cuid())
  restaurantId String
  title        String
  description  String?
  location     String?
  type         JobType  @default(VOLLZEIT)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  applicants Applicant[]

  @@index([restaurantId])
}

model Applicant {
  id           String           @id @default(cuid())
  restaurantId String
  jobId        String
  firstName    String
  lastName     String
  email        String
  phone        String?
  stage        ApplicationStage @default(EINGANG)
  sortOrder    Int              @default(0)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  restaurant Restaurant          @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  job        Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  notes      ApplicantNote[]
  documents  ApplicantDocument[]
  history    StageHistory[]

  @@index([restaurantId, jobId])
  @@index([jobId, stage])
}

model ApplicantNote {
  id          String   @id @default(cuid())
  applicantId String
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId, createdAt])
}

model ApplicantDocument {
  id          String   @id @default(cuid())
  applicantId String
  name        String
  url         String
  mimeType    String?
  createdAt   DateTime @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId])
}

model StageHistory {
  id          String            @id @default(cuid())
  applicantId String
  fromStage   ApplicationStage?
  toStage     ApplicationStage
  createdAt   DateTime          @default(now())

  applicant Applicant @relation(fields: [applicantId], references: [id], onDelete: Cascade)

  @@index([applicantId, createdAt])
}

// ─── BewerbungsBoard: E-Mail & Benachrichtigungen ───

enum EmailTemplateType {
  BESTAETIGUNG  // Bewerbungseingang bestätigen
  ABSAGE        // Absage
  EINLADUNG     // Interview-Einladung
  STATUS_UPDATE // Allgemeines Status-Update
  ANGEBOT       // Jobangebot
}

// Reusable email templates per organization
model EmailTemplate {
  id             String            @id @default(cuid())
  restaurantId   String
  type           EmailTemplateType
  name           String            // e.g. "Interview-Einladung Standard"
  subject        String            // Email subject with {{placeholders}}
  body           String            // HTML body with {{placeholders}}
  isDefault      Boolean           @default(false)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  emailLogs  EmailLog[]

  @@index([restaurantId, type])
}

// Audit log for sent emails
model EmailLog {
  id             String   @id @default(cuid())
  restaurantId   String
  templateId     String?
  recipientEmail String
  recipientName  String?
  subject        String
  body           String
  status         String   @default("pending") // pending, sent, failed
  resendId       String?  // Resend message ID for tracking
  errorMessage   String?
  sentAt         DateTime?
  createdAt      DateTime @default(now())

  restaurant Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([restaurantId, createdAt])
  @@index([templateId])
}
